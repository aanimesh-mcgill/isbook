{
  "name": "isbook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "seed": "node scripts/seed.mjs",
    "validate": "node scripts/validate.mjs",
    "publish": "node scripts/publish.mjs",
    "publish:section": "node scripts/publish-section.mjs",
    "archive:chapter": "node scripts/archive-chapter.mjs",
    "migrate:versions": "node scripts/migrate-versions.mjs",
    "import": "node scripts/import-deliverable.mjs",
    "atlas:assemble-tos": "node scripts/atlas-assemble-tos.mjs",
    "atlas:check-deps": "node scripts/atlas-check-deps.mjs",
    "atlas:sync-roadmap": "node scripts/atlas-sync-roadmap.mjs",
    "canonical:build": "node scripts/canonical-build.mjs",
    "atlas:init": "node scripts/atlas-init.mjs",
    "atlas:publish": "node scripts/atlas-publish.mjs",
    "author": "node scripts/author-section.mjs",
    "author:write": "node scripts/author-section.mjs --book database-analytics-ai --catalog v2 --out chapter",
    "author:chapter": "node scripts/author-chapter.mjs",
    "author:revise": "node scripts/author-revise.mjs",
    "author:student-review": "node scripts/author-student-review.mjs",
    "author:pipeline": "node scripts/author-pipeline.mjs",
    "firebase:deploy": "npm run build && firebase deploy",
    "firebase:rules": "firebase deploy --only firestore:rules,storage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-admin": "^14.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^5.2.0",
    "openai": "^6.45.0",
    "prettier": "^3.9.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
    "@tanstack/react-query": "^5.101.2",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1"
  }
}
