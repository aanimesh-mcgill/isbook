rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isStaff() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['author', 'editor', 'administrator'];
    }

    // Textbook images: public read, staff write
    match /books/{bookId}/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    // User uploads: owner only
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
